PORT=3000
NODE_ENV=development
# Supabase + Prisma — use the same names as Vercel’s Supabase integration (Prisma reads these, not DATABASE_URL).
# Transaction pooler :6543 (ORM / runtime). From Supabase → Connect → Prisma, or Vercel env POSTGRES_PRISMA_URL.
POSTGRES_PRISMA_URL=
# Non-pooling / direct URL for `prisma migrate` (Vercel: POSTGRES_URL_NON_POOLING).
POSTGRES_URL_NON_POOLING=
# Optional: append &connection_limit=5 on POSTGRES_PRISMA_URL so serverless does not exhaust the pool.
# If `prisma migrate deploy` fails with EMAXCONNSESSION, run: npm run prisma:migrate:apply-transaction
REDIS_URL=redis://127.0.0.1:6379

OPENAI_API_KEY=
# Firebase Admin (FCM delivery) — use ONE of:
# 1) Base64-encoded service account JSON (recommended for prod)
# FIREBASE_ADMIN_CREDENTIALS=
# 2) Path to service account JSON (local / Docker secret mount)
# FIREBASE_ADMIN_KEY_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=  # also accepted as JSON path
WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-flash-latest)
GEMINI_MODEL=gemini-flash-latest
