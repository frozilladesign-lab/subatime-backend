{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/api", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/**,packages/jyotisha-engine/dist/**,packages/jyotisha-engine/package.json,node_modules/@subatime/**,prisma/schema.prisma,node_modules/@prisma/client/**,node_modules/.prisma/client/**,node_modules/@swisseph/node/**,node_modules/@swisseph/core/**,node_modules/geo-tz/**}",
      "maxDuration": 60
    }
  }
}
